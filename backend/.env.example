# Abacus.AI API Configuration
ABACUS_API_KEY=
ABACUS_DEFAULT_LLM=route-llm

# Database Configuration
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
# For local development: postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}
# For Docker Compose: postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sop_writer

# Security
JWT_SECRET=super-secret-key-for-development-only

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email / SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Usage Limits
TOKEN_RESET_DAYS=30
DEFAULT_USER_TOKEN_LIMIT=50000
